{
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "hooks/risk-score.sh" }] }
    ],
    "PreToolUse": [
      { "matcher": "Edit|Write", "hooks": [{ "type": "command", "command": "hooks/secret-leak-gate.sh" }, { "type": "command", "command": "hooks/wip-risk-gate.sh" }] },
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "hooks/git-push-gate.sh" }] },
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "hooks/risk-score-commit-gate.sh" }] },
      { "matcher": "Edit|Write", "hooks": [{ "type": "command", "command": "hooks/risk-policy-enforce-edit.sh" }] },
      { "matcher": "ExitPlanMode", "hooks": [{ "type": "command", "command": "hooks/risk-score-plan-enforce.sh" }] },
      { "matcher": "EnterPlanMode", "hooks": [{ "type": "command", "command": "hooks/plan-risk-guidance.sh" }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "hooks": [{ "type": "command", "command": "hooks/wip-risk-mark.sh" }] },
      { "matcher": "Agent", "hooks": [{ "type": "command", "command": "hooks/risk-score-mark.sh" }] },
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "hooks/risk-hash-refresh.sh" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "hooks/risk-score-reset.sh" }] },
      { "hooks": [{ "type": "command", "command": "hooks/risk-policy-reset-marker.sh" }] }
    ]
  }
}
