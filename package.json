{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/windyroad/agent-plugins.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "bats": "^1.13.0",
    "bats-assert": "^2.2.4",
    "bats-support": "^0.3.0",
    "promptfoo": "^0.120.19"
  },
  "scripts": {
    "test": "bats --recursive packages/*/hooks/test/ packages/*/skills/*/test/ packages/*/agents/test/ packages/*/scripts/test/ packages/shared/test/ .claude/skills/*/test/",
    "eval:skills": "for cfg in packages/*/skills/*/eval/promptfooconfig.yaml; do echo \"--- $cfg ---\"; npx promptfoo eval -c \"$cfg\" || exit 1; done",
    "eval:architect:claude": "npx promptfoo eval -c packages/architect/skills/create-adr/eval/promptfooconfig.yaml",
    "eval:architect:codex": "npx promptfoo eval -c packages/architect/skills/create-adr/eval/promptfooconfig.codex.yaml && npx promptfoo eval -c packages/architect/agents/eval/promptfooconfig.codex.yaml",
    "eval:codex": "for cfg in packages/*/skills/*/eval/promptfooconfig.codex.yaml packages/*/agents/eval/promptfooconfig.codex.yaml; do [ -f \"$cfg\" ] || continue; echo \"--- $cfg ---\"; npx promptfoo eval -c \"$cfg\" || exit 1; done",
    "sync:install-utils": "bash scripts/sync-install-utils.sh",
    "check:install-utils": "bash scripts/sync-install-utils.sh --check",
    "sync:session-marker": "bash scripts/sync-session-marker.sh",
    "check:session-marker": "bash scripts/sync-session-marker.sh --check",
    "sync:external-comms-gate": "bash scripts/sync-external-comms-gate.sh",
    "check:external-comms-gate": "bash scripts/sync-external-comms-gate.sh --check",
    "sync:derive-first-dispatch": "bash scripts/sync-derive-first-dispatch.sh",
    "check:derive-first-dispatch": "bash scripts/sync-derive-first-dispatch.sh --check",
    "sync:command-detect": "bash scripts/sync-command-detect.sh",
    "check:command-detect": "bash scripts/sync-command-detect.sh --check",
    "sync:migrate-problems-layout": "bash scripts/sync-migrate-problems-layout.sh",
    "check:migrate-problems-layout": "bash scripts/sync-migrate-problems-layout.sh --check",
    "sync:plugin-manifests": "node scripts/sync-plugin-manifests.mjs",
    "check:plugin-manifests": "node scripts/sync-plugin-manifests.mjs --check",
    "sync:codex-plugin-manifests": "node scripts/sync-codex-plugin-manifests.mjs",
    "check:codex-plugin-manifests": "node scripts/sync-codex-plugin-manifests.mjs --check",
    "sync:codex-agents": "node scripts/sync-codex-agents.mjs",
    "check:codex-agents": "node scripts/sync-codex-agents.mjs --check",
    "check:agent-instructions": "node scripts/check-agent-instructions.mjs",
    "sync:shim-wrappers": "bash scripts/sync-shim-wrappers.sh",
    "check:shim-wrappers": "bash scripts/sync-shim-wrappers.sh --check",
    "version": "changeset version && node scripts/sync-plugin-manifests.mjs && node scripts/sync-codex-plugin-manifests.mjs && node scripts/sync-codex-agents.mjs",
    "release": "changeset publish",
    "release:watch": "bash scripts/release-watch.sh",
    "push:watch": "bash scripts/push-watch.sh"
  }
}
