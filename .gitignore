.DS_Store
*.tmp
node_modules/
*.tgz

# Runtime artifacts (created by risk-scorer hooks)
.risk-reports/
.env

# Skill eval workspaces (test-infrastructure scratch output per skill-creator)
*-workspace/

# Per-project consent caches — per-machine, never committed (P120 / ADR-034)
.claude/.install-updates-consent
.claude/.auto-install-consent

# Per-machine local permissions (Bash allowlist etc) — never committed
.claude/settings.local.json

# AFK runtime state — per-session, never committed (ADR-032 subprocess-boundary)
.afk-run-state/
.claude/scheduled_tasks.lock

# RFC capture deny log — measurement surface per ADR-060 § Reassessment
# (trace-violation-rate criterion). Per-session telemetry; CI runs and
# local development should not commit deny entries.
logs/

# Editor config (user-specific)
.vscode/

# Per-iter retro stragglers — kept local by default. Session-level retros
# (`docs/retros/YYYY-MM-DD-<name>.md` without an `-iter` suffix) are still
# tracked; force-add a tracked iter retro with `git add -f` when needed.
docs/retros/*-iter.md
docs/retros/*-iter-ask-hygiene.md
docs/retros/*-iter[0-9].md
docs/retros/*-iter[0-9]-ask-hygiene.md
